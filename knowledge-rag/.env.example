# === Required ===
ANTHROPIC_API_KEY=sk-ant-...

# === Qdrant ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_rag

# === Embedding / Reranker ===
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
EMBEDDING_BATCH_SIZE=32

# === LLM Provider ===
# Set to "deepseek" to use local vLLM instead of Anthropic (zero code changes)
LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=deepseek-ai/DeepSeek-R1-Distill-32B

# === Ingestion ===
DOCS_DIR=./data/reports
INGESTION_BATCH_SIZE=32

# === Domain Pack (optional) ===
# Path to a YAML file that injects domain-specific abbreviations, synonym
# groups, fields, unit patterns, and prompt overrides. Leave blank for a
# fully generic knowledge base.
DOMAIN_PACK_PATH=

# === Chunking ===
CHUNK_MIN_TOKENS=300
CHUNK_MAX_TOKENS=600
CHUNK_OVERLAP_TOKENS=50

# === Retrieval ===
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# === LangSmith Tracing (optional) ===
# Set LANGSMITH_API_KEY to enable LangGraph execution tracing
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=knowledge-rag

# === Logging ===
# Path to rotating log file (5 MB × 3 backups). Leave blank to disable.
LOG_FILE_PATH=~/.knowledge_rag.log

# === Access Control ===
# Set to enable password gate on the Streamlit app
APP_PASSWORD=

# === Agent Tuning ===
SYNTHESIS_TOP_K=30
WORKER_TIMEOUT_SECONDS=30
GRAPH_TIMEOUT_SECONDS=120
RERANK_MIN_SCORE=0.3
CRITIC_MAX_ROUNDS=3
